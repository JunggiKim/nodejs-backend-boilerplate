{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "services/example-service/src",
  "monorepo": true,
  "root": "services/example-service",
  "compilerOptions": {
    "builder": {
      "type": "swc",
      "options": {
        "swcrcPath": ".swcrc"
      }
    },
    "plugins": [
      {
        "name": "@nestjs/swagger",
        "options": {
          "introspectComments": true
        }
      }
    ],
    "deleteOutDir": true
  },
  "projects": {
    "example-service": {
      "type": "application",
      "root": "services/example-service",
      "entryFile": "main",
      "sourceRoot": "services/example-service/src",
      "compilerOptions": {
        "tsConfigPath": "services/example-service/tsconfig.app.json"
      }
    },
    "web-infra": {
      "type": "library",
      "root": "libs/web-infra",
      "entryFile": "index",
      "sourceRoot": "libs/web-infra/src",
      "compilerOptions": {
        "tsConfigPath": "libs/web-infra/tsconfig.lib.json"
      }
    },
    "util": {
      "type": "library",
      "root": "libs/util",
      "entryFile": "index",
      "sourceRoot": "libs/util/src",
      "compilerOptions": {
        "tsConfigPath": "libs/util/tsconfig.lib.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "cache": {
      "type": "library",
      "root": "external/cache",
      "entryFile": "index",
      "sourceRoot": "external/cache/src",
      "compilerOptions": {
        "tsConfigPath": "external/cache/tsconfig.lib.json"
      }
    },
    "message-queue": {
      "type": "library",
      "root": "external/message-queue",
      "entryFile": "index",
      "sourceRoot": "external/message-queue/src",
      "compilerOptions": {
        "tsConfigPath": "external/message-queue/tsconfig.lib.json"
      }
    },
    "storage": {
      "type": "library",
      "root": "external/storage",
      "entryFile": "index",
      "sourceRoot": "external/storage/src",
      "compilerOptions": {
        "tsConfigPath": "external/storage/tsconfig.lib.json"
      }
    },
    "monitoring": {
      "type": "library",
      "root": "support/monitoring",
      "entryFile": "index",
      "sourceRoot": "support/monitoring/src",
      "compilerOptions": {
        "tsConfigPath": "support/monitoring/tsconfig.lib.json"
      }
    }
  }
}
